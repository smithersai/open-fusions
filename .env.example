# smithers-fusions runs on your own smithers agents.
#
# By default it fuses the subscription harnesses you're already logged into
# (Claude Code, Codex, Gemini, …) via the `smithers agents` registry — NO API
# key required. Register one with: smithers agents add
#
# The variables below are only needed for the opt-in, key-billed backends:

# Durable run storage. Defaults to `.smithers-fusions/`.
SMITHERS_FUSIONS_DIR=

# OpenRouter — for `openrouter:<vendor/model>` panel/judge ids.
OPENROUTER_API_KEY=

# Any OpenAI-compatible endpoint (Ollama, vLLM, a gateway) — for `compat:<model>` ids.
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Native provider SDKs — for `anthropic:<model>` / `openai:<model>` ids.
ANTHROPIC_API_KEY=
